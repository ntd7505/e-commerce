# --- MySQL Database Configuration ---
# You can start a local MySQL instance using: docker compose up -d mysql
# Password defaults to 'root' as configured in docker-compose.yml
DB_URL=jdbc:mysql://localhost:3306/ecommerce_db?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# --- Redis Configuration ---
# You can start a local Redis instance using: docker compose up -d redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=1

# --- Application Settings ---
APP_ENV=dev
JPA_SHOW_SQL=false

# --- Email / Gmail SMTP ---
# Create a Gmail App Password after enabling 2-Step Verification.
# Do not use your normal Gmail password and never commit the real .env file.
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_APP_PASSWORD=your-16-character-gmail-app-password
MAIL_FROM=your-gmail-address@gmail.com

# --- Security ---
# IMPORTANT: Generate a random 64-character string for production use.
# You can generate one using: openssl rand -base64 48
JWT_SIGNER_KEY=replace-with-a-random-secret-containing-at-least-64-characters

# --- Payment Configuration ---
PAYMENT_BANK_CODE=VPB
PAYMENT_BANK_ACCOUNT=0987654321
PAYMENT_BANK_ACCOUNT_NAME=NGUYEN VAN A
PAYMENT_QR_TEMPLATE=compact
